# Vul deze waarden in Portainer in onder 'Environment variables' bij de stack
# (of, als je een stack.env gebruikt, hier). Commit NOOIT een echt wachtwoord.

# Deze stack draait achter een externe (systeem-)nginx die TLS termineert.
# Caddy luistert plat op :80 en wordt alleen op localhost gepubliceerd; de nginx
# proxyt hiernaartoe. Pas host/poort aan als nginx op een ander adres bindt.
# LET OP: kies een VRIJE poort. Portainer zelf gebruikt al 8000 (edge-tunnel)
# en 9000/9443 (UI). Check op de host met: sudo ss -tlnp | grep :<poort>
HTTP_BIND=127.0.0.1:8080

# Wachtwoord van de Virtuoso dba-gebruiker (wordt bij de eerste start gezet).
DBA_PASSWORD=verander-mij

# Basis-URI voor de named graphs; per bestand komt /<versie> erachter, plus /latest.
GRAPH_BASE=https://lod.gemeentelijkgegevensmodel.nl/graph

# Poort waarop de frontend-container luistert (generiek: 80; Ashkan: bijv. 3000).
FRONTEND_PORT=80

# Virtuoso-geheugen. 340000 buffers ~ 2,7 GB (veilig klein). 32 GB host: 1360000.
VIRT_BUFFERS=340000
VIRT_DIRTY=250000
